###############################################################################
### REQUIRED ENVIRONMENT VARIABLES - SENSITIVE INFORMATION                  ###
### DO NOT STORE RAW SECRETS HERE IN PLAINTEXT IF AVOIDABLE                 ###
### DO NOT UPLOAD OR SHARE THIS FILE UNDER ANY CIRCUMSTANCES                ###
###############################################################################

# Your deployer wallet private key (with 0x prefix)
CRE_ETH_PRIVATE_KEY=0x

# Default target environment for CRE
CRE_TARGET=staging-settings

# Google Gemini API key (get free tier from https://ai.google.dev)
GEMINI_API_KEY=

# RPC endpoint for Polygon / Tenderly Virtual TestNet fork
# Production: https://polygon-rpc.com or Alchemy/Infura Polygon endpoint
# Testing:    Your Tenderly Virtual TestNet RPC URL
POLYGON_RPC_URL=https://polygon-rpc.com

# Tenderly Virtual TestNet RPC URL (replace with your fork URL)
TENDERLY_RPC_URL=

# Polymarket CLOB API credentials (only needed for order execution, NOT price reads)
# Generate at: https://polymarket.com/settings?tab=builder
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# --------------------------------------------------
# Deployed contract addresses (fill in after deploy)
# --------------------------------------------------
PRICE_ORACLE_ADDRESS=
MARKET_REGISTRY_ADDRESS=
VAULT_ADDRESS=
LENDING_POOL_ADDRESS=

# --------------------------------------------------
# Market configuration (one market for V1)
# --------------------------------------------------
# Polymarket YES token ID for the market you're using as collateral
POLYMARKET_TOKEN_ID=
MARKET_ID=1
